class ClienteOllama:
    """Gerencia a comunicação com o servidor Ollama."""

    def __init__(self):
        self.session = requests.Session()

    def gerar(self, prompt: str, mostrar_stream: bool = True) -> str:
        """Envia prompt e retorna a resposta completa."""
        payload = {
            "model": CONFIG["modelo"],
            "prompt": prompt,
            "stream": True,
            "options": {"temperature": CONFIG["temperatura"]},
        }
        resposta = ""
        try:
            with self.session.post(
                CONFIG["url_ollama"],
                json=payload,
                stream=True,
                timeout=CONFIG["timeout"],
            ) as r:
                r.raise_for_status()
                for line in r.iter_lines():
                    if line:
                        token = json.loads(line.decode()).get("response", "")
                        if mostrar_stream:
                            print(token, end="", flush=True)
                        resposta += token
        except requests.exceptions.ConnectionError:
            raise RuntimeError(
                "Não foi possível conectar ao Ollama. "
                "Verifique se ele está rodando: `ollama serve`"
            )
        return resposta

    def verificar_conexao(self) -> bool:
        try:
            r = self.session.get("http://localhost:11434", timeout=3)
            return r.status_code == 200
        except Exception:
            return False


