#  EXECUTOR DE CÓDIGO
# ══════════════════════════════════════════════

class Executor:
    """Salva e executa código gerado pela IA no diretório Sandbox."""

    def __init__(self, sandbox: str):
        self.sandbox = Path(sandbox)

    def executar(self, codigo: str) -> tuple[bool, str]:
        # Segurança primeiro
        seguro, motivo = AnalisadorSeguranca.analisar(codigo)
        if not seguro:
            return False, f"[BLOQUEADO pela análise de segurança] {motivo}"

        # Salva arquivo
        nome = f"exec_{int(time.time())}.py"
        caminho = self.sandbox / nome
        caminho.write_text(codigo, encoding="utf-8")

        try:
            env = os.environ.copy()
            env["PYTHONIOENCODING"] = "utf-8"
            env["PYTHONDONTWRITEBYTECODE"] = "1"
            resultado = subprocess.run(
                [sys.executable, "-X", "frozen_modules=off", str(caminho)],
                capture_output=True,
                text=True,
                encoding="utf-8",
                timeout=CONFIG["timeout_execucao"],
                env=env,
            )
            # Filtra linhas de lixo do debugger
            linhas_limpas = [
                l for l in (resultado.stdout + resultado.stderr).splitlines()
                if not any(ruido in l for ruido in (
                    "Debugger warning", "frozen modules", "pydevd",
                    "PYDEVD", "0.00s -", "0.02s -", "debugger"
                ))
            ]
            saida = "\n".join(linhas_limpas).strip()
            return resultado.returncode == 0, saida or "(sem saída)"
        except subprocess.TimeoutExpired:
            return False, "Timeout: o código demorou mais de 15 segundos."
        except Exception as e:
            return False, f"Erro ao executar: {e}"
        finally:
            # Limpa o arquivo após execução
            try:
                caminho.unlink()
            except Exception:
                pass


