#  PACHECO AI — NÚCLEO PRINCIPAL
# ══════════════════════════════════════════════

class PachecoAI:
    """
    Orquestra todos os componentes do sistema.
    Este é o 'cérebro' do Pacheco AI.
    """

    def __init__(self):
        self._inicializar_estrutura()
        # Injeta o diretório raiz do projeto nos prompts
        PromptBuilder.DIR_PROJETO = str(Path(__file__).parent.resolve())
        self.memoria = Memoria(
            os.path.join(DIRETORIOS["memoria"], "memoria_longa.json")
        )
        self.executor = Executor(DIRETORIOS["sandbox"])
        self.cliente = ClienteOllama()
        self.logger = Logger(DIRETORIOS["logs"])

    def _inicializar_estrutura(self):
        for pasta in DIRETORIOS.values():
            os.makedirs(pasta, exist_ok=True)

    def processar(self, pergunta: str) -> dict:
        """
        Processa uma pergunta e tenta gerar + executar código.
        Retorna um dict com os detalhes da execução.
        """
        resultado = {
            "pergunta": pergunta,
            "resposta": "",
            "codigo": "",
            "saida": "",
            "sucesso": False,
            "tentativas": 0,
        }

        # Só busca solução anterior se a pergunta envolver arquivos/estoque
        palavras_chave_arquivo = ("arquivo", "json", "estoque", "salv", "leia", "ler", "venda", "produto")
        usar_memoria = any(p in pergunta.lower() for p in palavras_chave_arquivo)
        solucao_anterior = self.memoria.buscar_solucao_anterior(pergunta) if usar_memoria else None
        if solucao_anterior:
            print("\n[💾 Memória] Encontrei uma solução similar no histórico.\n")

        codigo_atual = ""
        erro_atual = ""

        for tentativa in range(1, CONFIG["max_tentativas_correcao"] + 2):
            resultado["tentativas"] = tentativa

            # Monta o prompt certo
            if tentativa == 1:
                prompt = PromptBuilder.inicial(
                    pergunta,
                    self.memoria.contexto_recente(),
                    solucao_anterior,
                )
            else:
                print(f"\n[🔄 Tentativa {tentativa}] Corrigindo erro anterior...\n")
                prompt = PromptBuilder.correcao(
                    pergunta, codigo_atual, erro_atual, tentativa
                )

            # Chama o modelo
            print(f"\n{'─'*50}")
            resposta = self.cliente.gerar(prompt)
            resultado["resposta"] = resposta
            print()  # linha após o stream

            # Extrai código da resposta
            blocos = REGEX_CODIGO.findall(resposta)
            if not blocos:
                print("[⚠️] Nenhum bloco de código encontrado na resposta.")
                self.logger.log("AVISO", f"Sem código para: {pergunta}")
                break

            codigo_atual = blocos[0]
            resultado["codigo"] = codigo_atual

            # Executa
            sucesso, saida = self.executor.executar(codigo_atual)
            resultado["saida"] = saida
            resultado["sucesso"] = sucesso

            print(f"\n{'─'*50}")
            print(f"[{'✅ SUCESSO' if sucesso else '❌ FALHOU'}] {saida}")

            if sucesso:
                self.logger.log("SUCESSO", f"Pergunta: {pergunta[:80]}")
                break
            else:
                erro_atual = saida
                self.logger.log("ERRO", f"Tentativa {tentativa}: {saida[:200]}")

        # Salva na memória
        self.memoria.adicionar(
            usuario=pergunta,
            resposta_ia=resultado["resposta"],
            codigo_gerado=resultado["codigo"],
            sucesso=resultado["sucesso"],
        )

        return resultado

    def executar_loop(self):
        """Loop principal de interação com o usuário."""
        print("\n" + "═"*55)
        print("  PACHECO AI Ω — v2.0 | LIMA CORP")
        print("  Sistema de IA Evolutivo")
        print("═"*55)

        # Verifica conexão com Ollama
        if not self.cliente.verificar_conexao():
            print("\n[ERRO CRÍTICO] Ollama não está rodando!")
            print("Execute: ollama serve")
            print(f"E baixe o modelo: ollama pull {CONFIG['modelo']}")
            return

        print(f"\n✅ Conectado ao Ollama | Modelo: {CONFIG['modelo']}")
        print(f"💾 Memória longa: {len(self.memoria.longo_prazo)} entradas")
        print("\nComandos especiais:")
        print("  'memoria'  → ver histórico da sessão")
        print("  'config'   → ver configurações")
        print("  'sair'     → encerrar")
        print("\nPara enviar um comando, termine com '---' em uma linha.\n")

        while True:
            try:
                print("\n" + "─"*55)
                print("📝 COMANDO (termine com '---'):")
                linhas = []
                while True:
                    linha = input()
                    if linha.strip() == "---":
                        break
                    linhas.append(linha)

                user_input = "\n".join(linhas).strip()
                if not user_input:
                    continue

                # Comandos internos
                if user_input.lower() in ("sair", "exit", "quit"):
                    print("\n👋 Até mais!")
                    break

                if user_input.lower() == "memoria":
                    self._mostrar_memoria()
                    continue

                if user_input.lower() == "config":
                    print(json.dumps(CONFIG, indent=2, ensure_ascii=False))
                    continue

                # Processa com IA
                self.processar(user_input)

            except KeyboardInterrupt:
                print("\n\n[Interrompido] Use 'sair' para encerrar.")
            except RuntimeError as e:
                print(f"\n[ERRO DE CONEXÃO] {e}")
                break
            except Exception as e:
                print(f"\n[ERRO INESPERADO] {e}")
                self.logger.log("ERRO_FATAL", str(e))

    def _mostrar_memoria(self):
        print("\n── MEMÓRIA DA SESSÃO ATUAL ──")
        if not self.memoria.curto_prazo:
            print("(vazia)")
            return
        for i, h in enumerate(self.memoria.curto_prazo, 1):
            ts = h["timestamp"][:19].replace("T", " ")
            status = "✅" if h["sucesso"] else "❌"
            print(f"\n{i}. [{ts}] {status}")
            print(f"   Pergunta: {h['usuario'][:70]}...")

        print(f"\n── MEMÓRIA LONGA: {len(self.memoria.longo_prazo)} soluções salvas ──")


