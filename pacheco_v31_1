#  SISTEMA DE MEMÓRIA
# ══════════════════════════════════════════════

class Memoria:
    """
    Memória de dois níveis:
      - Curto prazo: lista em RAM, descartada ao sair
      - Longo prazo: arquivo JSON persistente entre sessões
    """

    def __init__(self, caminho_arquivo: str):
        self.curto_prazo: list[dict] = []
        self.arquivo = Path(caminho_arquivo)
        self.longo_prazo: list[dict] = self._carregar()

    def _carregar(self) -> list:
        if self.arquivo.exists():
            try:
                with open(self.arquivo, "r", encoding="utf-8") as f:
                    return json.load(f)
            except Exception:
                return []
        return []

    def _salvar(self):
        with open(self.arquivo, "w", encoding="utf-8") as f:
            json.dump(self.longo_prazo[-CONFIG["limite_memoria_longa"]:], f,
                      ensure_ascii=False, indent=2)

    def adicionar(self, usuario: str, resposta_ia: str, codigo_gerado: str = "", sucesso: bool = False):
        entrada = {
            "timestamp": datetime.now().isoformat(),
            "usuario": usuario,
            "resposta_ia": resposta_ia,
            "codigo_gerado": codigo_gerado,
            "sucesso": sucesso,
        }
        # Curto prazo (RAM)
        self.curto_prazo.append(entrada)
        if len(self.curto_prazo) > CONFIG["limite_memoria_curta"]:
            self.curto_prazo.pop(0)

        # Longo prazo (apenas interações com código bem-sucedido)
        if sucesso and codigo_gerado:
            self.longo_prazo.append(entrada)
            self._salvar()

    def contexto_recente(self) -> str:
        if not self.curto_prazo:
            return "(nenhum histórico ainda)"
        linhas = []
        for h in self.curto_prazo:
            linhas.append(f"User: {h['usuario']}")
            linhas.append(f"Pacheco: {h['resposta_ia'][:300]}...")
        return "\n".join(linhas)

    def buscar_solucao_anterior(self, pergunta: str) -> str | None:
        """Busca no longo prazo se já resolvemos algo parecido."""
        palavras = set(pergunta.lower().split())
        for entrada in reversed(self.longo_prazo):
            palavras_entrada = set(entrada["usuario"].lower().split())
            similaridade = len(palavras & palavras_entrada) / max(len(palavras), 1)
            if similaridade > 0.5 and entrada["codigo_gerado"]:
                return entrada["codigo_gerado"]
        return None


# ══════════════════════════════════════════════
#  SEGURANÇA — ANÁLISE DE AST
# ══════════════════════════════════════════════

class AnalisadorSeguranca:
    """
    Analisa o código Python gerado pela IA antes de executar.
    Usa AST (Abstract Syntax Tree) para encontrar chamadas perigosas
    sem precisar executar nada.
    """

    @staticmethod
    def analisar(codigo: str) -> tuple[bool, str]:
        """
        Retorna (seguro, motivo).
        seguro=True significa que pode executar.
        """
        # 1. Verifica se é Python válido
        try:
            arvore = ast.parse(codigo)
        except SyntaxError as e:
            return False, f"Erro de sintaxe: {e}"

        # 2. Percorre todos os nós da árvore
        for no in ast.walk(arvore):

            # Chamadas de função: os.system("rm -rf /")
            if isinstance(no, ast.Call):
                nome_chamada = AnalisadorSeguranca._nome_chamada(no)
                for bloqueado in CHAMADAS_BLOQUEADAS:
                    if nome_chamada and bloqueado in nome_chamada:
                        return False, f"Chamada bloqueada por segurança: '{nome_chamada}'"

            # Import de módulos bloqueados
            if isinstance(no, (ast.Import, ast.ImportFrom)):
                modulos = (
                    [alias.name for alias in no.names]
                    if isinstance(no, ast.Import)
                    else [no.module or ""]
                )
                for modulo in modulos:
                    if modulo and any(b.split(".")[0] == modulo.split(".")[0]
                                      for b in CHAMADAS_BLOQUEADAS):
                        # Permite os e json (usados legítimamente)
                        if modulo not in ("os", "json", "datetime", "re",
                                          "math", "random", "string", "pathlib",
                                          "collections", "itertools", "functools"):
                            return False, f"Import bloqueado: '{modulo}'"

        return True, "OK"

    @staticmethod
    def _nome_chamada(no: ast.Call) -> str | None:
        """Extrai o nome completo de uma chamada (ex: 'os.system')."""
        if isinstance(no.func, ast.Attribute):
            if isinstance(no.func.value, ast.Name):
                return f"{no.func.value.id}.{no.func.attr}"
        if isinstance(no.func, ast.Name):
            return no.func.id
        return None


