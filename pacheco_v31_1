class PromptBuilder:
    """Monta os prompts enviados ao modelo."""

    # DIR_PROJETO é injetado em runtime pelo PachecoAI
    DIR_PROJETO: str = ""

    @classmethod
    def _sistema(cls) -> str:
        return f"""Você é o Pacheco AI, assistente de IA da LIMA CORP.
Especialidades: Python, Gestão de Estoque, automações.
REGRAS OBRIGATÓRIAS:
1. Responda SEMPRE com exatamente um bloco ```python ... ``` contendo código funcional.
2. Use apenas: os, json, datetime, re, math, random, pathlib, collections.
3. O código deve ser independente (não dependa de variáveis externas).
4. Inclua print() para mostrar resultados ao usuário. Se usar função, SEMPRE chame ela fora da função.
5. Nunca use subprocess, requests, eval, exec, ou __import__.
6. NUNCA use Path(__file__). O diretório raiz do projeto é SEMPRE: r"{cls.DIR_PROJETO}"
   Exemplo correto para abrir arquivo: open(r"{cls.DIR_PROJETO}/Sandbox/estoque.json")
7. Todo print() deve ser uma expressão simples, NUNCA coloque ':' depois do parêntese de fechamento.
8. ESCREVA APENAS EM PORTUGUÊS. Nomes de variáveis, comentários e textos SOMENTE em português.
   PROIBIDO usar espanhol: 'productos', 'costo', 'precio' são ERROS GRAVES. Use: 'produtos', 'custo', 'preco'.
9. Revise TODAS as variáveis antes de usar. Nunca use uma variável com nome diferente do que foi definido."""

    @staticmethod
    def inicial(pergunta: str, contexto: str, solucao_anterior: str | None) -> str:
        partes = [
            PromptBuilder._sistema(),
            f"\nHISTÓRICO RECENTE:\n{contexto}",
        ]
        if solucao_anterior:
            partes.append(
                f"\nREFERÊNCIA (solução similar do passado):\n```python\n{solucao_anterior}\n```"
            )
        partes.append(f"\nTAREFA: {pergunta}")
        return "\n".join(partes)

    @staticmethod
    def correcao(pergunta: str, codigo_falho: str, erro: str, tentativa: int) -> str:
        sistema = PromptBuilder._sistema()
        dir_proj = PromptBuilder.DIR_PROJETO
        return (
            f"{sistema}\n\n"
            f"TAREFA ORIGINAL: {pergunta}\n\n"
            f"TENTATIVA {tentativa} FALHOU.\n"
            f"CÓDIGO COM ERRO:\n```python\n{codigo_falho}\n```\n\n"
            f"MENSAGEM DE ERRO:\n{erro}\n\n"
            f"CORRIJA o código. Use r\"{dir_proj}\" como diretório raiz.\n"
            f"Responda APENAS com o bloco ```python corrigido."
        )


