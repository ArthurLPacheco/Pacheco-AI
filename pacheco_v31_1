class Logger:
    def __init__(self, caminho: str):
        self.arquivo = Path(caminho) / f"sessao_{datetime.now().strftime('%Y%m%d_%H%M%S')}.log"

    def log(self, nivel: str, mensagem: str):
        linha = f"[{datetime.now().strftime('%H:%M:%S')}] [{nivel}] {mensagem}\n"
        with open(self.arquivo, "a", encoding="utf-8") as f:
            f.write(linha)


