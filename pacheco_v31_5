class ClienteOllama:

    def __init__(self):
        self.session = requests.Session()

    def verificar(self) -> bool:
        try:
            return self.session.get("http://localhost:11434", timeout=3).status_code == 200
        except Exception:
            return False

    def gerar(self, prompt: str, temperatura: float | None = None) -> str:
        if temperatura is None:
            temperatura = CONFIG["temperatura_codigo"]

        payload = {
            "model":   CONFIG["modelo"],
            "prompt":  prompt,
            "stream":  True,
            "options": {"temperature": temperatura},
        }
        resposta = ""
        try:
            with self.session.post(
                CONFIG["url_ollama"],
                json=payload,
                stream=True,
                timeout=CONFIG["timeout_resposta"],
            ) as r:
                r.raise_for_status()
                for linha in r.iter_lines():
                    if linha:
                        token = json.loads(linha.decode()).get("response", "")
                        print(token, end="", flush=True)
                        resposta += token
        except requests.exceptions.ConnectionError:
            raise RuntimeError("Ollama offline. Execute: ollama serve")
        return resposta


