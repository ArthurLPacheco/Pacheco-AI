class Executor:

    def __init__(self, sandbox: str):
        self.sandbox = Path(sandbox)

    def executar(self, codigo: str) -> tuple[bool, str]:
        seguro, motivo = AnalisadorSeguranca.analisar(codigo)
        if not seguro:
            return False, f"[BLOQUEADO] {motivo}"

        nome = f"exec_{int(time.time() * 1000)}.py"
        caminho = self.sandbox / nome
        caminho.write_text(codigo, encoding="utf-8")

        try:
            env = os.environ.copy()
            env["PYTHONIOENCODING"] = "utf-8"
            env["PYTHONUTF8"] = "1"
            env["PYTHONDONTWRITEBYTECODE"] = "1"

            resultado = subprocess.run(
                [sys.executable, "-X", "utf8", str(caminho)],
                capture_output=True,
                text=True,
                encoding="utf-8",
                errors="replace",
                timeout=CONFIG["timeout_execucao"],
                env=env,
            )

            stdout = Executor._limpar(resultado.stdout).strip()
            stderr = Executor._limpar(resultado.stderr).strip()

            if resultado.returncode != 0:
                return False, stderr or stdout or "Erro desconhecido"

            if not stdout:
                return False, (
                    "Código executou sem erros mas sem saída. "
                    "Certifique-se de chamar print() com os resultados FORA de qualquer função."
                )

            return True, stdout

        except subprocess.TimeoutExpired:
            return False, f"Timeout: execução ultrapassou {CONFIG['timeout_execucao']}s."
        except Exception as e:
            return False, f"Erro ao executar: {e}"
        finally:
            try:
                caminho.unlink()
            except Exception:
                pass

    @staticmethod
    def _limpar(texto: str) -> str:
        return "\n".join(
            l for l in texto.splitlines()
            if not any(r in l for r in RUIDO_DEBUGGER)
        )


