class Classificador:
    """Classificador de intenção — usado APENAS no modo /auto."""

    @staticmethod
    def classificar(texto: str) -> str:
        """Retorna 'codigo' ou 'chat'."""
        t = texto.lower().strip()

        # Gatilhos fortes de código têm prioridade absoluta
        if any(g in t for g in _GATILHOS_CODIGO_FORTE):
            return "codigo"

        score_codigo   = sum(1 for g in _GATILHOS_CODIGO_FRACO if g in t)
        score_conversa = sum(1 for g in _GATILHOS_CONVERSA if g in t)

        # Empate ou conversa vence → chat (mais seguro, evita rodar código indesejado)
        if score_codigo > score_conversa + 1:
            return "codigo"
        if score_conversa > 0:
            return "chat"
        if score_codigo > 0:
            return "codigo"

        # Fallback: texto curto → chat, texto longo → código
        return "chat" if len(t.split()) <= 10 else "codigo"

    @staticmethod
    def estimar_complexidade(texto: str) -> str:
        """Retorna 'simples', 'medio' ou 'complexo'."""
        t = texto.lower()
        palavras = len(t.split())

        gatilhos_complexo = (
            "quais são", "quais sao", "me lista", "me explica detalhado",
            "quais as vantagens", "quais os", "como posso", "como eu posso",
            "estratégia", "estrategia", "comparação", "comparacao",
            "diferença entre", "diferenca entre", "me dê exemplos",
            "me dá exemplos", "ideia de negócio", "produtos que", "o que seria",
        )
        if any(g in t for g in gatilhos_complexo) or palavras > 15:
            return "complexo"
        if palavras <= 5:
            return "simples"
        return "medio"


