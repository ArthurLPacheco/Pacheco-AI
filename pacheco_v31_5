class Memoria:

    def __init__(self, caminho: str):
        self.curto_prazo: list[dict] = []
        self.arquivo = Path(caminho)
        self.longo_prazo: list[dict] = self._carregar()

    def _carregar(self) -> list:
        if self.arquivo.exists():
            try:
                return json.loads(self.arquivo.read_text(encoding="utf-8"))
            except Exception:
                return []
        return []

    def _salvar(self):
        dados = self.longo_prazo[-CONFIG["limite_memoria_longa"]:]
        self.arquivo.write_text(
            json.dumps(dados, ensure_ascii=False, indent=2),
            encoding="utf-8"
        )

    def adicionar(self, usuario: str, codigo: str, sucesso: bool):
        entrada = {
            "ts":      datetime.now().isoformat(),
            "usuario": usuario,
            "codigo":  codigo,
            "sucesso": sucesso,
        }
        self.curto_prazo.append(entrada)
        if len(self.curto_prazo) > CONFIG["limite_memoria_curta"]:
            self.curto_prazo.pop(0)

        if sucesso and codigo.strip():
            self.longo_prazo.append(entrada)
            self._salvar()

    def contexto_curto(self) -> str:
        if not self.curto_prazo:
            return "(sem histórico)"
        linhas = []
        for h in self.curto_prazo[-3:]:
            status = "OK" if h["sucesso"] else "FALHOU"
            linhas.append(f"[{status}] User: {h['usuario'][:120]}")
        return "\n".join(linhas)

    def buscar_similar(self, pergunta: str) -> str | None:
        gatilhos = ("arquivo", "json", "estoque", "salvar", "ler", "leia",
                    "venda", "produto", "relatorio", "relatório", "csv")
        if not any(g in pergunta.lower() for g in gatilhos):
            return None

        palavras = set(pergunta.lower().split())
        melhor_score = 0.0
        melhor = None

        for entrada in reversed(self.longo_prazo):
            p2 = set(entrada["usuario"].lower().split())
            if not p2:
                continue
            score = len(palavras & p2) / len(palavras | p2)
            if score > melhor_score and score >= 0.45:
                melhor_score = score
                melhor = entrada.get("codigo") or entrada.get("codigo_gerado") or ""

        return melhor


