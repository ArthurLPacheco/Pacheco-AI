_CHAMADAS_BLOQUEADAS = frozenset({
    "os.system", "os.popen", "os.remove", "os.rmdir", "os.unlink",
    "shutil.rmtree", "shutil.move", "shutil.copy",
    "subprocess.run", "subprocess.call", "subprocess.Popen", "subprocess.check_output",
    "eval", "exec", "compile", "__import__",
})

_MODULOS_PERMITIDOS = frozenset({
    "os", "json", "datetime", "re", "math", "random", "string",
    "pathlib", "collections", "itertools", "functools", "time",
})


class AnalisadorSeguranca:

    @staticmethod
    def analisar(codigo: str) -> tuple[bool, str]:
        try:
            arvore = ast.parse(codigo)
        except SyntaxError as e:
            return False, f"Sintaxe inválida: {e}"

        for no in ast.walk(arvore):
            if isinstance(no, ast.Call):
                nome = AnalisadorSeguranca._nome(no)
                if nome and nome in _CHAMADAS_BLOQUEADAS:
                    return False, f"Chamada bloqueada: '{nome}'"

            if isinstance(no, (ast.Import, ast.ImportFrom)):
                mods = (
                    [a.name for a in no.names]
                    if isinstance(no, ast.Import)
                    else [no.module or ""]
                )
                for mod in mods:
                    raiz = mod.split(".")[0]
                    if raiz and raiz not in _MODULOS_PERMITIDOS:
                        return False, f"Import não permitido: '{mod}'"

        return True, "OK"

    @staticmethod
    def _nome(no: ast.Call) -> str | None:
        if isinstance(no.func, ast.Attribute):
            if isinstance(no.func.value, ast.Name):
                return f"{no.func.value.id}.{no.func.attr}"
        if isinstance(no.func, ast.Name):
            return no.func.id
        return None


