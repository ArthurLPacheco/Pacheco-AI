class PachecoAI:

    VERSAO = "3.2"

    def __init__(self):
        self._criar_dirs()
        PromptBuilder.DIR_PROJETO = str(Path(__file__).parent.resolve())
        self.memoria  = Memoria(os.path.join(DIRETORIOS["memoria"], "memoria_longa.json"))
        self.executor = Executor(DIRETORIOS["sandbox"])
        self.cliente  = ClienteOllama()
        self.logger   = Logger(DIRETORIOS["logs"])
        self.chat     = ModuloChat(self.cliente)
        self.modo_atual: str = CONFIG["modo_padrao"]  # "chat" | "codigo" | "auto"

    def _criar_dirs(self):
        for p in DIRETORIOS.values():
            os.makedirs(p, exist_ok=True)

    # ── Gerenciador de modo ────────────────────────────────────
    def _trocar_modo(self, novo_modo: str):
        self.modo_atual = novo_modo
        icone = ICONE_MODO.get(novo_modo, "")
        nomes = {"chat": "CONVERSA", "codigo": "PROGRAMADOR", "auto": "AUTOMÁTICO"}
        print(f"\n{icone} Modo {nomes[novo_modo]} ativado.", end="")
        if novo_modo == "auto":
            print(" (Pacheco decide o modo com base no que você digitar)")
        elif novo_modo == "chat":
            print(" (Use /cod pra programar)")
        elif novo_modo == "codigo":
            print(" (Use /chat pra conversar)")
        print()

    # ── Parser de entrada ──────────────────────────────────────
    def _parsear_entrada(self, entrada: str) -> tuple[str, str]:
        """
        Retorna (acao, texto_limpo).
        acao pode ser: 'chat', 'codigo', 'comando:<nome>', 'modo:<nome>'
        """
        t = entrada.strip()
        t_lower = t.lower()

        # Verifica comandos rápidos /prefixo
        for prefixo, acao in _COMANDOS_RAPIDOS.items():
            if t_lower == prefixo or t_lower.startswith(prefixo + " "):
                texto_restante = t[len(prefixo):].strip()
                return acao, texto_restante

        # Sem prefixo: usa o modo atual ou auto-classifica
        if self.modo_atual == "auto":
            modo_inferido = Classificador.classificar(t)
            return modo_inferido, t
        else:
            return self.modo_atual, t

    # ── Roteador principal ────────────────────────────────────
    def rotear(self, entrada: str) -> None:
        acao, texto = self._parsear_entrada(entrada)

        # Troca de modo
        if acao.startswith("modo:"):
            self._trocar_modo(acao.split(":")[1])
            return

        # Comandos instantâneos
        if acao in ("hora", "data", "versao", "versão"):
            self._cmd_rapido(acao)
            return
        if acao == "memoria" or acao == "memória":
            self._cmd_memoria()
            return
        if acao == "config":
            print(json.dumps(CONFIG, indent=2, ensure_ascii=False))
            return
        if acao == "sair":
            raise SystemExit("sair")
        if acao == "ajuda":
            self._cmd_ajuda()
            return

        # Conversa
        if acao == "chat":
            complexidade = Classificador.estimar_complexidade(texto)
            icone = ICONE_MODO["chat"]
            print(f"\n{icone} [{complexidade}]\n")
            self.chat.responder(texto, complexidade)
            print()
            self.logger.log("CHAT", texto[:100])
            return

        # Código
        if acao == "codigo":
            print(f"\n{ICONE_MODO['codigo']} [MODO PROGRAMADOR]\n")
            self.processar(texto)
            return

    # ── Processador de código (lógica original) ───────────────
    def processar(self, pergunta: str) -> dict:
        resultado = {
            "pergunta":   pergunta,
            "codigo":     "",
            "saida":      "",
            "sucesso":    False,
            "tentativas": 0,
        }

        similar = self.memoria.buscar_similar(pergunta)
        if similar:
            print("[Memória] Referência similar encontrada.\n")

        codigo_atual = ""
        erro_atual   = ""

        for tentativa in range(1, CONFIG["max_tentativas"] + 1):
            resultado["tentativas"] = tentativa

            if tentativa == 1:
                prompt = PromptBuilder.inicial(pergunta, self.memoria.contexto_curto(), similar)
            else:
                print(f"\n[Tentativa {tentativa}/{CONFIG['max_tentativas']}] Corrigindo...\n")
                prompt = PromptBuilder.correcao(pergunta, codigo_atual, erro_atual, tentativa)

            print(f"{'─'*55}")
            resposta_capturada = self.cliente.gerar(prompt)
            print()

            blocos = REGEX_CODIGO.findall(resposta_capturada)

            if not blocos:
                erro_atual = "Nenhum bloco ```python``` na resposta."
                print(f"[AVISO] {erro_atual}")
                continue

            codigo_atual = blocos[-1].strip()
            resultado["codigo"] = codigo_atual

            sucesso, saida = self.executor.executar(codigo_atual)
            resultado["saida"]   = saida
            resultado["sucesso"] = sucesso

            print(f"\n{'─'*55}")
            print(f"[{'✅ SUCESSO' if sucesso else '❌ FALHOU'}]\n{saida}")

            if sucesso:
                self.logger.log("SUCESSO", pergunta[:100])
                break
            else:
                erro_atual = saida
                self.logger.log("ERRO", f"T{tentativa}: {saida[:200]}")

        self.memoria.adicionar(pergunta, codigo_atual, resultado["sucesso"])
        return resultado

    def _gerar_silencioso(self, prompt: str) -> str:
        """Gera sem fazer stream (pra capturar o texto completo internamente)."""
        payload = {
            "model":   CONFIG["modelo"],
            "prompt":  prompt,
            "stream":  False,
            "options": {"temperature": CONFIG["temperatura_codigo"]},
        }
        try:
            r = self.cliente.session.post(
                CONFIG["url_ollama"],
                json=payload,
                timeout=CONFIG["timeout_resposta"],
            )
            r.raise_for_status()
            return r.json().get("response", "")
        except Exception:
            return ""

    # ── Comandos rápidos ──────────────────────────────────────
    def _cmd_rapido(self, tipo: str):
        agora = datetime.now()
        if tipo in ("hora",):
            print(f"\nSão {agora.strftime('%H:%M')} ⏰")
        elif tipo in ("data",):
            dias   = ["Segunda", "Terça", "Quarta", "Quinta", "Sexta", "Sábado", "Domingo"]
            meses  = ["janeiro","fevereiro","março","abril","maio","junho",
                      "julho","agosto","setembro","outubro","novembro","dezembro"]
            print(f"\nHoje é {dias[agora.weekday()]}, {agora.day} de {meses[agora.month-1]} de {agora.year} 📅")
        elif tipo in ("versao", "versão"):
            print(f"\nPacheco AI Ω v{self.VERSAO} | LIMA CORP — by Arthur Lima 🤖")

    def _cmd_ajuda(self):
        icone = ICONE_MODO.get(self.modo_atual, "")
        modo_nome = {"chat": "CONVERSA", "codigo": "PROGRAMADOR", "auto": "AUTOMÁTICO"}.get(self.modo_atual, self.modo_atual)
        print(f"""
┌─ PACHECO AI Ω v{self.VERSAO} ─ AJUDA ──────────────────────┐
│                                                       │
│  MODO ATUAL: {icone} {modo_nome:<38}│
│                                                       │
│  TROCAR MODO:                                         │
│    /chat  → Modo Conversa  (papo, ideias, análise)    │
│    /cod   → Modo Programador (gera e roda Python)     │
│    /auto  → Modo Automático (Pacheco decide)          │
│                                                       │
│  COMANDOS RÁPIDOS:                                    │
│    /hora    → que horas são                           │
│    /data    → data de hoje                            │
│    /versao  → versão do sistema                       │
│    /memoria → histórico da sessão                     │
│    /config  → configurações atuais                    │
│    /ajuda   → esta tela                               │
│    /sair    → encerrar                                │
│                                                       │
│  DICA: Termine textos longos (multiparagrafo) com --- │
└───────────────────────────────────────────────────────┘""")

    def _cmd_memoria(self):
        print("\n── SESSÃO ATUAL ──")
        if not self.memoria.curto_prazo:
            print("(vazia)")
        else:
            for i, h in enumerate(self.memoria.curto_prazo, 1):
                ts = h["ts"][:19].replace("T", " ")
                ok = "✅" if h["sucesso"] else "❌"
                print(f"{i}. [{ts}] {ok} {h['usuario'][:65]}...")
        print(f"\nMemória longa: {len(self.memoria.longo_prazo)} soluções persistidas")

    # ── Loop principal ────────────────────────────────────────
    def executar(self):
        print("\n" + "═"*55)
        print(f"  PACHECO AI Ω v{self.VERSAO} | LIMA CORP")
        print(f"  by Arthur Lima")
        print("═"*55)

        if not self.cliente.verificar():
            print("\nOllama offline! Execute: ollama serve")
            print(f"Depois: ollama pull {CONFIG['modelo']}")
            return

        modo_nome = {"chat": "CONVERSA 💬", "codigo": "PROGRAMADOR ⌨️", "auto": "AUTOMÁTICO 🤖"}
        print(f"\nOnline | Modelo: {CONFIG['modelo']}")
        print(f"Memória longa: {len(self.memoria.longo_prazo)} soluções salvas")
        print(f"Modo inicial: {modo_nome.get(self.modo_atual, self.modo_atual)}")
        print(f"\n/chat → conversa | /cod → código | /auto → automático | /ajuda → ajuda\n")

        while True:
            try:
                icone = ICONE_MODO.get(self.modo_atual, "")
                print(f"\n{'─'*55}")
                print(f"VOCÊ {icone}:")

                linhas = []
                while True:
                    linha = input()
                    if linha.strip() == "---":
                        break
                    if not linha.strip() and linhas:
                        break
                    if linha.strip():
                        linhas.append(linha)
                    if not linha.strip() and not linhas:
                        continue

                entrada = "\n".join(linhas).strip()
                if not entrada:
                    continue

                self.rotear(entrada)

            except SystemExit as e:
                if str(e) == "sair":
                    print(f"\nFalou, Arthur! Até mais. 👋")
                break
            except KeyboardInterrupt:
                print("\n[Ctrl+C] Use /sair pra encerrar.")
            except RuntimeError as e:
                print(f"\nERRO: {e}")
                break
            except Exception as e:
                import traceback
                print(f"\n[ERRO INESPERADO] {e}")
                print(traceback.format_exc())
                self.logger.log("FATAL", traceback.format_exc())


